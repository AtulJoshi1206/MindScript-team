# MindScript Environment Variables
# Copy this file to .env. Google is tried first; local Ollama/Whisper/TTS are fallbacks.
# NEVER commit .env to git — it's in .gitignore

# Primary Google API key for Gemini chat, Gemini audio transcription, and Google TTS.
# Leave blank to use only local fallbacks.
GOOGLE_API_KEY=

# Optional Google model and voice overrides
GOOGLE_CHAT_MODEL=gemini-1.5-flash
GOOGLE_TTS_HI_LANGUAGE=hi-IN
GOOGLE_TTS_HI_VOICE=hi-IN-Wavenet-D
GOOGLE_TTS_EN_LANGUAGE=en-US
GOOGLE_TTS_EN_VOICE=en-US-Wavenet-F
GOOGLE_TTS_SPEAKING_RATE=0.95

# Local fallback chat backend
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen2.5

# Local fallback voice settings
WHISPER_MODEL=small
WHISPER_ALLOWED_LANGUAGES=hi,en
WHISPER_PREFERRED_LANGUAGE=auto
TTS_VOICE=
TTS_VOICE_HI=
TTS_VOICE_EN=
